# Application
APP_PORT=3000
APP_NODE_ENV=development
APP_CLUSTERING=false

# Project metadata
PROJECT_NAME=Task Management API
PROJECT_DESCRIPTION=Production-ready task management API
PROJECT_VERSION=0.1.0

# Swagger docs access
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=admin

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=task_manager
DATABASE_SCHEMA=public
DATABASE_SSL=false

# LLM Gemini
LLM_GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
LLM_GEMINI_API_KEY=your-gemini-api-key
LLM_GEMINI_MODEL=models/gemini-1.5-pro
LLM_GEMINI_TEMPERATURE=0.2
LLM_GEMINI_MAX_OUTPUT_TOKENS=1024

